

@{
    List<Empleado> empleados = Context.Session.GetObject<List<Empleado>>("EMPLEADOS");
}
@{
    ViewData["Title"] = "EmpleadosAlmacenados";
}

<h1>EmpleadosAlmacenados</h1>

@if(empleados!=null){
<table class="table table-dark">
    <thead>
        <tr>
            <th>
                IdEmpleado
            </th>
            <th>
                Apellido
            </th>
            <th>
                Oficio
            </th>
            <th>
                Salario
            </th>
            <th>
                IdDepartamento
            </th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in empleados)
        {
            <tr>
                <td>
                    @item.IdEmpleado
                </td>
                <td>
                    @item.Apellido
                </td>
                <td>
                    @item.Oficio
                </td>
                <td>
                    @item.Salario
                </td>
                <td>
                     @item.IdDepartamento
                </td>
                
            </tr>
        }
    </tbody>
</table>
}
else
{
    <h2 style="color:red">No hay nada en session</h2>
}